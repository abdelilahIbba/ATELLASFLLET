# ─── Atellas Fleet — Root Docker Environment ────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
#
# cp .env.example .env

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Atellas Fleet"
APP_ENV=production
APP_KEY=          # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost

# ── Ports ────────────────────────────────────────────────────────────────────
NGINX_PORT=80
DB_EXTERNAL_PORT=3307
REDIS_EXTERNAL_PORT=6380

# ── Database ─────────────────────────────────────────────────────────────────
DB_DATABASE=atellasfleet_db
DB_USERNAME=fleet_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@atellasfleet.ma

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_GEMINI_API_KEY=
