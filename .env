# ─── Atellas Fleet — Root Docker Environment ────────────────────────────────
# This file is mounted as the Laravel .env inside the backend container
# AND used by docker compose to expand ${VAR} references in docker-compose.yml.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Atellas Fleet"
APP_ENV=production
APP_KEY=base64:ne9zzjp7BjG+OQkihmkw2tFauhFPz2yYfqnHH5lEKEQ=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# ── Ports (docker-compose only) ──────────────────────────────────────────────
NGINX_PORT=8080
NGINX_SSL_PORT=8443
DB_EXTERNAL_PORT=3309
REDIS_EXTERNAL_PORT=6380

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=atellasfleet_db
DB_USERNAME=fleet_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Mail (log driver — no SMTP required) ─────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@atellasfleet.ma
MAIL_FROM_NAME="Atellas Fleet"

# ── Demo email sender (your personal address) ────────────────────────────────
DEMO_MAIL_FROM_ADDRESS=elibbawiabdelilah@gmail.com
DEMO_MAIL_FROM_NAME="Abdelilah Ibbawi"

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:8080

# ── Frontend (Vite build-time vars) ──────────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_GEMINI_API_KEY=
